# Database
DATABASE_URL=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Socket.io server
SOCKET_PORT=
NEXT_PUBLIC_SOCKET_URL=

# Backend base URL for client fetches + realtime socket (lib/apiBase.ts).
# Web/desktop: leave empty so requests stay same-origin.
# Mobile (Capacitor): set to the hosted backend, e.g. https://chatpulse.example.com
NEXT_PUBLIC_API_URL=

# Capacitor dev live-reload target (optional): your machine's LAN address so an
# Android emulator/device can reach the running dev server, e.g. http://192.168.1.20:3000
CAP_SERVER_URL=
