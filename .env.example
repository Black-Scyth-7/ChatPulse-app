# Database
DATABASE_URL=

# NextAuth
# NEXTAUTH_URL must be the app's public origin — it drives OAuth callback URLs,
# Socket.io CORS, and secure-cookie selection (server/index.ts).
# Local dev: http://localhost:3000
# Production (Render): https://chatpulse-gk3z.onrender.com
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Socket.io server
SOCKET_PORT=
NEXT_PUBLIC_SOCKET_URL=

# Backend base URL for client fetches + realtime socket (lib/apiBase.ts).
# Web/desktop: leave empty so requests stay same-origin.
# Mobile (Capacitor): set to the hosted backend, e.g. https://chatpulse-gk3z.onrender.com
NEXT_PUBLIC_API_URL=

# Firebase Cloud Messaging (Android push notifications — CHAA-55).
# The service-account JSON key generated in the Firebase console (Project
# settings → Service accounts → Generate new private key). Paste the raw JSON on
# one line, or base64-encode it — lib/firebase.ts accepts either. Leave empty on
# web/desktop deployments; offline push is then simply disabled.
FIREBASE_SERVICE_ACCOUNT=

# Capacitor (remote-webview) backend URL the Android app loads via server.url.
# Prod: your hosted HTTPS deployment, e.g. https://chatpulse-gk3z.onrender.com
# Dev live-reload: your machine's LAN address (not localhost), e.g. http://192.168.1.20:3000
# Falls back to NEXT_PUBLIC_API_URL when unset. Read at `cap sync` time.
CAP_SERVER_URL=
