// ChatPulse Prisma schema — the single source of truth for the data model.
// Owned by DatabaseEng (CHAA-5). App code accesses data only via the generated
// Prisma client; no raw SQL in application code.
// Auth models follow the Auth.js (NextAuth) Prisma adapter conventions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// Realtime presence, driven by the Socket.io presence_update event.
enum UserStatus {
  ONLINE
  OFFLINE
  AWAY
}

/// A member's role within a channel.
enum ChannelMemberRole {
  OWNER
  ADMIN
  MEMBER
}

// ---------------------------------------------------------------------------
// Users & NextAuth (Prisma adapter spec)
// ---------------------------------------------------------------------------

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  // Presence tracking for the online/away/offline indicator.
  status        UserStatus @default(OFFLINE)
  lastSeen      DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts           Account[]
  sessions           Session[]
  channelMemberships ChannelMember[]
  createdChannels    Channel[]                       @relation("ChannelCreatedBy")
  messages           Message[]
  dmParticipations   DirectConversationParticipant[]
  directMessages     DirectMessage[]

  @@index([status])
}

/// OAuth account link (GitHub). Matches the NextAuth Prisma adapter.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// Database session record. Matches the NextAuth Prisma adapter.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Email verification token. Matches the NextAuth Prisma adapter.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Channels & membership
// ---------------------------------------------------------------------------

model Channel {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPrivate   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Restrict: a channel outlives its creator's account deletion rather than
  // silently taking the whole channel (and its messages) down.
  createdBy User            @relation("ChannelCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  members   ChannelMember[]
  messages  Message[]

  @@index([createdById])
}

model ChannelMember {
  id         String            @id @default(cuid())
  channelId  String
  userId     String
  role       ChannelMemberRole @default(MEMBER)
  // Backs unread-count computation: messages after lastReadAt are unread.
  lastReadAt DateTime          @default(now())
  joinedAt   DateTime          @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
  @@index([channelId])
}

// ---------------------------------------------------------------------------
// Channel messages
// ---------------------------------------------------------------------------

/// A single channel message. Soft-delete (deletedAt) / edit (editedAt) back the
/// message_deleted / message_edited realtime events.
model Message {
  id        String    @id @default(cuid())
  // Markdown body (rendered client-side with react-markdown + remark-gfm).
  body      String    @db.Text
  authorId  String
  channelId String
  editedAt  DateTime?
  // Soft delete: non-null once the message is deleted; rows are never hard-deleted.
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  // Hot path: paginating a channel's history newest-first.
  @@index([channelId, createdAt])
  @@index([authorId])
}

// ---------------------------------------------------------------------------
// Direct messages
// ---------------------------------------------------------------------------

/// A direct-message conversation between two (or more) participants.
model DirectConversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants DirectConversationParticipant[]
  messages     DirectMessage[]
}

model DirectConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  // Backs DM unread counts.
  lastReadAt     DateTime @default(now())
  joinedAt       DateTime @default(now())

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

/// A single direct message within a DirectConversation. Soft-delete (deletedAt)
/// / edit (editedAt) mirror the channel Message behavior.
model DirectMessage {
  id             String    @id @default(cuid())
  body           String    @db.Text
  authorId       String
  conversationId String
  editedAt       DateTime?
  // Soft delete: non-null once the message is deleted; rows are never hard-deleted.
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  author       User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Hot path: paginating a DM conversation's history.
  @@index([conversationId, createdAt])
  @@index([authorId])
}
