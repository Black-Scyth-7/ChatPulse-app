{
  "name": "chatpulse",
  "version": "0.1.0",
  "private": true,
  "description": "ChatPulse — realtime team chat, wrapped as a desktop app.",
  "author": "ChatPulse",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "tsx server/index.ts",
    "dev:next": "next dev",
    "build": "next build",
    "start": "tsx server/index.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:start": "electron .",
    "electron:dev": "concurrently -k -n next,electron -c blue,magenta \"pnpm dev\" \"wait-on http://localhost:3000 && pnpm electron:compile && pnpm electron:start\"",
    "electron:build": "next build && pnpm electron:compile && electron-builder --win",
    "mobile:build": "cap sync",
    "mobile:open": "cap open android",
    "mobile:run": "cap run android",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "build": {
    "appId": "com.chatpulse.desktop",
    "productName": "ChatPulse",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/dist/**/*",
      ".next/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/icon.png",
        "to": "icon.png"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Black-Scyth-7",
        "repo": "ChatPulse-app"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.2.1",
    "@capacitor/push-notifications": "^8.1.2",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@prisma/client": "^6.2.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.9",
    "firebase-admin": "^14.2.0",
    "next": "^15.1.4",
    "next-auth": "^5.0.0-beta.25",
    "postcss": "^8.4.49",
    "prisma": "^6.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.4",
    "wait-on": "^9.0.10"
  }
}
